<job retention_tag="Scratch">
    <whiteboard>This job was scheduled from the dci-rhel-agent using XML template.</whiteboard>
    <recipeSet priority="Normal">
        {% if hostvars.localhost.system_arch == 'ppc64le' and beaker_lab.system_inventory[fqdn].petitboot|default(False, true) == False %}
                 <recipe ks_meta="selinux=--permissive autopart_type=plain skip_taskrepo=1 {% if 'RHEL-9' in topic_name %}harness='restraint' no_default_harness_repo disabled_root_access=True {% else %}harness='restraint beakerlib' {% endif%} {% if ks_meta is defined %}{{ ks_meta }}{% endif %}" whiteboard="" kernel_options="netbootloader=boot/grub2/{{ fqdn }}/powerpc-ieee1275/core.elf {% if kernel_options is defined %}{{ kernel_options }}{% endif %}">
        {% elif hostvars.localhost.system_arch == 'aarch64' and beaker_lab.system_inventory[fqdn].efi|default(False, true) == True %}
                <recipe ks_meta="selinux=--permissive autopart_type=plain skip_taskrepo=1 {% if 'RHEL-9' in topic_name %}harness='restraint' no_default_harness_repo disabled_root_access=True {% else %}harness='restraint beakerlib' {% endif%} {% if ks_meta is defined %}{{ ks_meta }}{% endif %}" whiteboard="" kernel_options="netbootloader=grubaa64.efi {% if kernel_options is defined %}{{ kernel_options }}{% endif %}">
        {% elif hostvars.localhost.system_arch == 'x86_64' and beaker_lab.system_inventory[fqdn].efi|default(False, true) == True %}
                <recipe ks_meta="selinux=--permissive autopart_type=plain skip_taskrepo=1 {% if 'RHEL-9' in topic_name %}harness='restraint' no_default_harness_repo disabled_root_access=True {% else %}harness='restraint beakerlib' {% endif%} {% if ks_meta is defined %}{{ ks_meta }}{% endif %}" whiteboard="" kernel_options="netbootloader=grubx64.efi {% if kernel_options is defined %}{{ kernel_options }}{% endif %} ">
        {% elif hostvars.localhost.system_arch == 'x86_64' and beaker_lab.system_inventory[fqdn].efi|default(False, true) == False %}
                <recipe ks_meta="selinux=--permissive autopart_type=plain skip_taskrepo=1 {% if 'RHEL-9' in topic_name %}harness='restraint' no_default_harness_repo disabled_root_access=True {% else %}harness='restraint beakerlib' {% endif%} {% if ks_meta is defined %}{{ ks_meta }}{% endif %}" whiteboard="" kernel_options="{% if kernel_options is defined %}{{ kernel_options }}{% endif %}">
        {% else %}
                <recipe ks_meta="selinux=--permissive autopart_type=plain skip_taskrepo=1 {% if 'RHEL-9' in topic_name %}harness='restraint' no_default_harness_repo disabled_root_access=True {% else %}harness='restraint beakerlib' {% endif%} {% if ks_meta is defined %}{{ ks_meta }}{% endif %}" whiteboard="" kernel_options="{% if kernel_options is defined %}{{ kernel_options }}{% endif %}">
        {% endif %}
              <distro>
                  <tree url="http://{{ local_repo_ip }}/{{ topic_name }}/compose/{{ distro_variant }}/{{ hostvars.localhost.system_arch }}/os/"/>
                  <initrd url="images/pxeboot/initrd.img"/>
                  <kernel url="images/pxeboot/vmlinuz"/>
                  <arch value="{{ hostvars.localhost.system_arch }}"/>
                  <osversion major="{{ distro_osmajor }}" minor="{{ distro_osminor }}"/>
                  <name value="{{ distro_name }}"/>
                  <variant value="Server"/>
              </distro>
            {% if fqdn is defined %}
                    <hostRequires force="{{ fqdn }}" />
            {% else %}
            <hostRequires/>
            {% endif %}
            <repos>
            {% for item in repos %}
              <repo name="{{ item.name }}" url="http://{{ local_repo_ip }}/{{ item.path }}"/>
            {% endfor %}
            {% if 'RHEL-7' in topic_name %}
              <repo name="extraos-local" url="http://{{ local_repo_ip }}/{{ topic_name }}/extraos/Server/{{ hostvars.localhost.system_arch }}/os"/>
            {% endif %}
            {% if 'RHEL-9' in topic_name %}
              <repo name="harness-almost-nine" url="http://{{ local_repo_ip }}/beaker/harness/RedHatEnterpriseLinux8/"/>
            {% endif %}
            </repos>
            <partitions/>
            <task name="/distribution/check-install" role="STANDALONE">
                <params>
                </params>
            </task>
            <reservesys/>
        </recipe>
    </recipeSet>
</job>
